@using FishFocus.Shared.Models
@using MudBlazor

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column align-center py-4" style="min-width: 300px;">
            @if (CatchResult?.Fish != null)
            {
                @if (!string.IsNullOrEmpty(CatchResult.Fish.ImageUrl))
                {
                    <div class="fish-image-container mb-4">
                        <MudImage Src="@CatchResult.Fish.ImageUrl" 
                                  Width="160" 
                                  Height="160" 
                                  Alt="@CatchResult.Fish.Name" 
                                  ObjectFit="ObjectFit.Contain"
                                  Class="rounded-lg mud-elevation-4 pa-2" 
                                  Style="background: rgba(255,255,255,0.1); border: 2px solid var(--mud-palette-primary);"/>
                    </div>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.QuestionMark" Size="Size.Large" Class="mb-4" />
                }

                <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: bold; text-align: center;">
                    @CatchResult.Fish.Name
                </MudText>
                
                <div class="mt-4" style="text-align: center;">
                    <MudText Typo="Typo.h6">Начислено: <b>+@CatchResult.TotalPoints pts</b></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Базовые: @CatchResult.BasePoints | Бонус: +@CatchResult.TimeBonus
                    </MudText>
                </div>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Class="mt-2">Загрузка улова...</MudText>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Success" 
                   OnClick="HandleClose" 
                   FullWidth="true" 
                   Size="Size.Large"
                   Style="height: 50px; font-weight: bold;">
            ЗАБРАТЬ НАГРАДУ
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] 
    public FishCatchResult CatchResult { get; set; } = default!;

    [Parameter] 
    public bool IsNight { get; set; }

    private void HandleClose() => MudDialog.Close();
}