@using FishFocus.Shared.Models
@using MudBlazor

<MudDialog Class="@(IsNight ? "night-dialog-inner" : "")">
    <DialogContent>
        <div class="d-flex flex-column align-center py-4" style="min-width: 300px;">
            @if (CatchResult?.Fish != null)
            {
                <div class="fish-image-container mb-4">
                    @if (!string.IsNullOrEmpty(CatchResult.Fish.ImageUrl))
                    {
                        <MudImage Src="@CatchResult.Fish.ImageUrl" 
                                  Width="160" 
                                  Height="160" 
                                  Alt="@CatchResult.Fish.Name" 
                                  ObjectFit="ObjectFit.Contain"
                                  Class="@(IsNight ? "rounded-lg mud-elevation-4 pa-2 fish-image-container-night" : "rounded-lg mud-elevation-4 pa-2")" />
                    }
                </div>

                <MudText Typo="Typo.h4" Color="Color.Primary" Class="font-weight-bold text-center">
                    @CatchResult.Fish.Name
                </MudText>
                
                <div class="mt-4 text-center">
                    <MudText Typo="Typo.h6">Начислено: <b>+@CatchResult.TotalPoints pts</b></MudText>
                    <MudText Typo="Typo.body2" Class="@(IsNight ? "text-night-muted" : "mud-text-secondary")">
                        Базовые: @CatchResult.BasePoints | Бонус: +@CatchResult.TimeBonus
                    </MudText>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Success" 
                   OnClick="HandleClose" 
                   FullWidth="true" 
                   Size="Size.Large"
                   Class="py-3 font-weight-bold">
            ЗАБРАТЬ НАГРАДУ
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public FishCatchResult CatchResult { get; set; } = default!;
    [Parameter] public bool IsNight { get; set; }
    private void HandleClose() => MudDialog.Close(DialogResult.Ok(true));
}