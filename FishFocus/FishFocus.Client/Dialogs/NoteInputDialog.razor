@using MudBlazor

<MudDialog CloseButton="true">
    <TitleContent>
        <MudText Typo="Typo.h6">Что вы успели сделать?</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" 
                      Label="Ваш успех (макс. 50 символов)" 
                      @bind-Value="NoteText" 
                      Immediate="true"
                      Counter="50" 
                      MaxLength="50" 
                      AutoFocus="true"
                      Variant="Variant.Outlined" 
                      Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Закрыть</MudButton>
        
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="Submit" 
                   Disabled="@(string.IsNullOrWhiteSpace(NoteText))"> 
            Сохранить
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private string NoteText { get; set; } = "";

    private void Submit() => MudDialog.Close(DialogResult.Ok(NoteText));
    
    private void Cancel() => MudDialog.Cancel();
}