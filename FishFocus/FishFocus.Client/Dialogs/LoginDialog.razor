@using System.ComponentModel.DataAnnotations
@using FishFocus.Shared.DTOs.Auth
@using FishFocus.Client.Services
@using MudBlazor
@inject AuthApiService AuthApi
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTabs Outlined="true" Position="Position.Top" Rounded="true" Border="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Вход">
                <MudForm @ref="loginForm">
                    <MudTextField T="string" Label="Email" Required="true" 
                                  Variant="Variant.Outlined" Class="mb-4" @bind-Value="loginModel.Email" />
                    <MudTextField T="string" Label="Пароль" InputType="InputType.Password" 
                                  Required="true" Variant="Variant.Outlined" @bind-Value="loginModel.Password" />

                    <div class="d-flex justify-center mt-6">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" 
                                   OnClick="HandleLogin" FullWidth="true" Disabled="isLoading">
                            @(isLoading ? "Загрузка..." : "ВОЙТИ")
                        </MudButton>
                    </div>
                </MudForm>
            </MudTabPanel>

            <MudTabPanel Text="Регистрация">
                <MudForm @ref="registerForm">
                    <MudTextField T="string" Label="Имя пользователя" Required="true" 
                                  Variant="Variant.Outlined" Class="mb-4" @bind-Value="regModel.Username" />
                    <MudTextField T="string" Label="Email" Required="true" 
                                  Variant="Variant.Outlined" Class="mb-4" @bind-Value="regModel.Email" />
                    <MudTextField T="string" Label="Пароль" InputType="InputType.Password" 
                                  Required="true" Variant="Variant.Outlined" Class="mb-4" @bind-Value="regModel.Password" />
                    <MudTextField T="string" Label="Подтверждение пароля" InputType="InputType.Password" 
                                  Required="true" Variant="Variant.Outlined" @bind-Value="regModel.ConfirmPassword" />

                    <div class="d-flex justify-center mt-6">
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" 
                                   OnClick="HandleRegister" FullWidth="true" Disabled="isLoading">
                            @(isLoading ? "Загрузка..." : "СОЗДАТЬ АККАУНТ")
                        </MudButton>
                    </div>
                </MudForm>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? loginForm;
    private MudForm? registerForm;
    private bool isLoading = false;

    private LoginRequest loginModel = new();
    private RegisterRequest regModel = new();

    private async Task HandleLogin()
    {
        isLoading = true;
        try
        {
            var result = await AuthApi.LoginAsync(loginModel);

            if (result is not null && result.Success)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "jwt_token", result.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "username", result.Username);
                Snackbar.Add($"Добро пожаловать, {result.Username}!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(result));
            }
            else
            {
                var errors = result?.Errors ?? new List<string> { "Неизвестная ошибка" };
                foreach (var err in errors)
                    Snackbar.Add(err, Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Ошибка подключения к серверу", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleRegister()
    {
        isLoading = true;
        try
        {
            var result = await AuthApi.RegisterAsync(regModel);

            if (result is not null && result.Success)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "jwt_token", result.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "username", result.Username);
                Snackbar.Add($"Аккаунт создан! Добро пожаловать, {result.Username}!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(result));
            }
            else
            {
                var errors = result?.Errors ?? new List<string> { "Неизвестная ошибка" };
                foreach (var err in errors)
                    Snackbar.Add(err, Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Ошибка подключения к серверу", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
