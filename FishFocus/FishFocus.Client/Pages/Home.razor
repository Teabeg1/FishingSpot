@page "/"
@rendermode InteractiveWebAssembly
@using FishFocus.Shared.Models
@using System.Threading
@using MudBlazor
@using FishFocus.Client.Dialogs
@implements IDisposable
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Рыбалка</PageTitle>

<div class="main-container @(isNightMode ? "night-theme" : "day-theme")">
    
    <div class="lake-area" id="lake-container" @onclick="HandleLakeClick">
        <div class="fog-overlay @(playFog ? "fog-active" : "")"></div>

        @if (isRainEnabled) 
        {
            <div class="rain-overlay" @key="@("rain-layer-v3")">
                @for (int i = 0; i < 60; i++) 
                {
                    var leftPosition = (i * 1.67) % 100; 
                    var fallDelay = (i * 0.05) % 2;
                    var fallDuration = 0.6 + (i % 4) * 0.1;

                    <div class="rain-drop" 
                         style="left: @(leftPosition.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; 
                                animation-delay: @(fallDelay.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s; 
                                animation-duration: @(fallDuration.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s;">
                    </div>
                }
            </div>
        }

        <div class="progress-container">
            <MudProgressCircular Color="Color.Primary"
                                 Value="@_progressValue" 
                                 Size="Size.Large" 
                                 Thickness="2"
                                 Style="height:300px; width:300px;">
                <ChildContent>
                     @if (isRunning)
                     {
                        <div class="fishing-scene">
                            <div class="water-line"></div>
                            <div class="bobber @GetFishingAnimationClass()">
                                <div class="bobber-top"></div>
                            </div>
                            <div class="ripples"></div>
                            <div class="splash-effect @(showSplash ? "splash-active" : "")"></div>
                        </div>
                     }
                </ChildContent>
            </MudProgressCircular>
        </div>

        <MudText Typo="Typo.h1" Class="timer-text">@timeDisplay</MudText>

        <div class="quote-area">
            <MudText Typo="Typo.body1" Class="italic-quote">"@_currentQuote"</MudText>
        </div>
        
        @if (!isRunning)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" 
                       OnClick="StartTimer" Class="action-button">
                Забросить удочку
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" 
                       OnClick="StopTimer" Class="action-button">
                Прервать рыбалку
            </MudButton>
        }
    </div>

<div class="settings-panel">

    <div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h6">Настройки</MudText>
    <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" OnClick="OpenLoginDialog" />
    </div>

    <MudText Typo="Typo.overline" Class="mb-2 d-block" Style="text-align:center">Время фокусировки</MudText>
    
<div class="time-picker-container">
    <div class="time-box" 
         @onmousedown='(e) => HandleMouseDown(e, "hours")'
         @onmouseup="HandleMouseUp"
         @onmouseleave="HandleMouseUp"
         @ondblclick='() => EnableInputMode("hours")'>
        
        @if (isHoursInputMode)
        {
            <input id="h-input-field" type="number" class="time-input-hidden" 
                   value="@displayHours" 
                   @onchange='(e) => ManualUpdate(e, "hours")' 
                   @onblur='() => isHoursInputMode = false'
                   @onkeydown="@(e => { if (e.Key == "Enter") isHoursInputMode = false; })" />
        }
        
        <span class="time-value">@displayHours</span>
        <span class="time-label">ч</span>
    </div>

    <div class="time-box" 
         @onmousedown='(e) => HandleMouseDown(e, "minutes")'
         @onmouseup="HandleMouseUp"
         @onmouseleave="HandleMouseUp"
         @ondblclick='() => EnableInputMode("minutes")'>
        
        @if (isMinutesInputMode)
        {
            <input id="m-input-field" type="number" class="time-input-hidden" 
                   value="@displayMinutes" 
                   @onchange='(e) => ManualUpdate(e, "minutes")' 
                   @onblur='() => isMinutesInputMode = false' />
        }
        <span class="time-value">@displayMinutes.ToString("D2")</span>
        <span class="time-label">мин</span>
    </div>
</div>
    <div class="d-flex align-center justify-space-between mb-2">
        <MudSwitch @bind-Value="isNightMode" Label="Ночной режим" Color="Color.Secondary" />
    </div>

        <div class="d-flex align-center justify-space-between mb-2">
            <MudSwitch Value="isRadioEnabled" 
                       T="bool"
                       ValueChanged="ToggleRadio" 
                       Label="Радио" 
                       Color="Color.Secondary" />
    
            @if (isRadioEnabled)
            {
                <div style="width: 120px;" class="ml-4">
                    <MudSlider T="int" 
                               Value="radioVolume" 
                               ValueChanged="UpdateRadioVolume" 
                               Min="0" Max="100" 
                               Size="Size.Small"
                               Color="Color.Secondary">
                        <span class="volume-label" style="font-size: 12px;">Громкость: @radioVolume%</span>
                    </MudSlider>
                </div>
            }

        </div>

        <div class="d-flex align-center justify-space-between mb-2">
            <MudSwitch Value="isRainEnabled" 
                       T="bool"
                       ValueChanged="ToggleRain" 
                       Label="Дождь" 
                       Color="Color.Info" />
    
            @if (isRainEnabled)
            {
                <div style="width: 120px;" class="ml-4">
                    <MudSlider T="int" 
                               Value="rainVolume" 
                               ValueChanged="UpdateRainVolume" 
                               Min="0" Max="100" 
                               Size="Size.Small"
                               Color="Color.Info">
                        <span class="volume-label" style="font-size: 12px;">Громкость: @rainVolume%</span>
                    </MudSlider>
                </div>
            }

        </div>

        <div class="d-flex align-center justify-space-between mb-4">
            <MudSwitch @bind-Value="playFog" Label="Туман" Color="Color.Default" />
        </div>

        <MudDivider Class="my-4"/>
        
        @if (showDevTools)
        {
            <TestTools IsRunning="@isRunning" 
                       SelectedMinutes="@selectedMinutes" 
                       OnFastForward="@(() => secondsLeft = 5)" />
        }

        <audio id="radio-audio" src="@currentTrackUrl" @onended="PlayNextTrack"></audio>
    </div>
</div>

<audio id="rain-audio" src="audio/rain.mp3" loop></audio>

@code {
    private bool isRadioEnabled = false;
    private int radioVolume = 50;
    private string currentTrackUrl = "";
    private int currentTrackIndex = 1;
    private bool isRadioInitialized = false;
    private bool isRainEnabled = false;
    private int rainVolume = 50;
    private bool playFog = false;
    private bool showDevTools = true;
    private bool showSplash = false;
    private bool isNightMode = false;
    private int selectedMinutes = 30;
    private int secondsLeft = 1800;
    private bool isRunning = false;
    private double _progressValue = 0;
    private string _currentQuote = "Забросьте удочку и начните путь к спокойствию...";
    private bool _halfTimeNagSent = false;
    private PeriodicTimer? timer;
    private CancellationTokenSource cts = new();
    private FishCatchResult? catchResult;
    private int TotalScore = 0;
    private List<FishCatchResult> CatchHistory = new();
    private string timeDisplay => $"{(secondsLeft / 60):D2}:{(secondsLeft % 60):D2}";
    private CancellationTokenSource? _adjustCts;
    private bool _isAdjusting = false;
    private async Task ToggleRadio(bool value)
    {
        isRadioEnabled = value;

        if (isRadioEnabled)
        {
            try 
            {
                if (!isRadioInitialized)
                {
                    currentTrackIndex = Random.Shared.Next(1, 11);
                    currentTrackUrl = $"audio/radio/track{currentTrackIndex}.mp3";
                    isRadioInitialized = true;
                    StateHasChanged();
                    await Task.Delay(300);
                    await JS.InvokeVoidAsync("audioInterop.play", "radio-audio");
                    double randomStartTime = Random.Shared.Next(10, 60); 
                    await JS.InvokeVoidAsync("audioInterop.setCurrentTime", "radio-audio", randomStartTime);
                }
                await UpdateRadioVolume(radioVolume);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка радио: {ex.Message}");

            }
        }
        else
        {
            await JS.InvokeVoidAsync("audioInterop.setVolume", "radio-audio", 0);
        }
    }

    private async Task UpdateRadioVolume(int value)
    {
        radioVolume = value;
        int actualVolume = isRadioEnabled ? radioVolume : 0;
        await JS.InvokeVoidAsync("audioInterop.setVolume", "radio-audio", actualVolume);
    }

    private async Task PlayNextTrack()
    {
        currentTrackIndex = currentTrackIndex >= 10 ? 1 : currentTrackIndex + 1;
        currentTrackUrl = $"audio/radio/track{currentTrackIndex}.mp3";
    
        StateHasChanged();
        await Task.Delay(100);
    
        await JS.InvokeVoidAsync("audioInterop.play", "radio-audio");
        await UpdateRadioVolume(radioVolume);
    }

    private async Task OpenLoginDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LoginDialog>("Личный кабинет", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            Snackbar.Add("Запрос отправлен бэкенд-бро!", Severity.Info);
        }
    }

    private int displayHours = 0;
    private int displayMinutes = 30;
    private bool isHoursInputMode = false;
    private bool isMinutesInputMode = false;
    private bool isMouseDown = false;
    private void SyncSelectedMinutes()
    {
        if (displayHours >= 2) 
        {
            displayHours = 2;
            displayMinutes = 0;
        }
        
        selectedMinutes = (displayHours * 60) + displayMinutes;
        if (selectedMinutes < 1) selectedMinutes = 1;
        
        if (!isRunning) secondsLeft = selectedMinutes * 60;
        StateHasChanged();
    }

    private async Task HandleMouseDown(MouseEventArgs e, string type)
    {
        if (isRunning || isHoursInputMode || isMinutesInputMode) return;

        bool isTopHalf = e.OffsetY < 40;
        int step = isTopHalf ? 1 : -1;

        _isAdjusting = true;
        _adjustCts = new CancellationTokenSource();

        try
        {
            int currentDelay = 300;
            
            while (_isAdjusting)
            {
                ChangeValue(type, step);
                StateHasChanged();

                await Task.Delay(currentDelay, _adjustCts.Token);

                if (currentDelay > 50) currentDelay -= 40; 
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleMouseUp()
    {
        _isAdjusting = false;
        _adjustCts?.Cancel();
    }

    private void HandleWheel(WheelEventArgs e, string type)
    {
        if (isRunning || !isMouseDown) return;

        int step = e.DeltaY < 0 ? 1 : -1;
        ChangeValue(type, step);
    }

    private void ChangeValue(string type, int step)
    {
        if (isHoursInputMode || isMinutesInputMode) return;

        if (type == "hours")
        {
            displayHours += step;
            if (displayHours > 2) displayHours = 0;
            if (displayHours < 0) displayHours = 2;
        }
        else
        {
            displayMinutes += step;
            if (displayMinutes > 59) displayMinutes = 0;
            if (displayMinutes < 0) displayMinutes = 59;
        }
        SyncSelectedMinutes();
    }

    private async Task EnableInputMode(string type)
    {
        if (isRunning) return;
        HandleMouseUp();
        if (type == "hours") isHoursInputMode = true;
        else isMinutesInputMode = true;
        StateHasChanged();  
        await Task.Delay(50);
        string elementId = type == "hours" ? "h-input-field" : "m-input-field";
        await JS.InvokeVoidAsync("audioInterop.focusElement", elementId);
    }

    private void ManualUpdate(ChangeEventArgs e, string type)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            if (type == "hours") displayHours = Math.Clamp(val, 0, 2);
            else displayMinutes = Math.Clamp(val, 0, 59);
        }
        isHoursInputMode = false;
        isMinutesInputMode = false;
        SyncSelectedMinutes();
    }

    private readonly string[] _quotes = new[]
    {
        "Терпение — это ключ к самому крупному улову.",
        "Труд рыбака незаметен, пока в сетях пусто.",
        "Рыбалка — это не про рыбу, это про спокойствие.",
        "Тишина — лучший друг рыбака.",
        "Даже самая маленькая рыбка лучше, чем пустое ведро.",
        "Настоящий рыбак видит не только рыбу, но и красоту момента.",
        "Рыбак рыбака видит издалека."
    };

    private enum FishingAnimationState { None, InitialDrop, PassiveFishing, ActiveBite, FinalRaise }
    private FishingAnimationState _animationState = FishingAnimationState.None;

    private async Task StartTimer()
    {
        if (isRunning) return;
        isRunning = true;
        _progressValue = 0;
        secondsLeft = selectedMinutes * 60;
        int totalSeconds = secondsLeft;
        double thresholdSeconds = (double)totalSeconds * 0.10;
        _halfTimeNagSent = false;
        catchResult = null;
        _currentQuote = _quotes[Random.Shared.Next(_quotes.Length)];
        _animationState = FishingAnimationState.InitialDrop;
        await TriggerSplash();
        _animationState = FishingAnimationState.PassiveFishing;
        cts = new CancellationTokenSource();
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(cts.Token) && secondsLeft > 0)
            {
                secondsLeft--;
                _progressValue = ((double)(totalSeconds - secondsLeft) / totalSeconds) * 100;

                if (!_halfTimeNagSent && secondsLeft <= totalSeconds / 2)
                {
                    Snackbar.Add("Рыба уже кружит рядом!", Severity.Info);
                    _halfTimeNagSent = true;
                }

                if (secondsLeft <= thresholdSeconds && _animationState == FishingAnimationState.PassiveFishing)
                {
                    _animationState = FishingAnimationState.ActiveBite;
                }

                if (secondsLeft % 30 == 0 && secondsLeft > 0)
                {
                    _currentQuote = _quotes[Random.Shared.Next(_quotes.Length)];
                }

                StateHasChanged();
            }

            if (secondsLeft == 0)
            {
                await FinishSession();
            }
        }
        catch (OperationCanceledException) { }
    }

private async Task FinishSession()
{
    _animationState = FishingAnimationState.FinalRaise;
    await TriggerSplash();
    isRunning = false;
    timer?.Dispose();
    cts.Cancel();

    try 
    {
        var response = await Http.GetFromJsonAsync<FishCatchResult>($"api/fishery/catch?minutes={selectedMinutes}");
        if (response != null) 
        {
            catchResult = response;
            TotalScore += response.TotalPoints;
            CatchHistory.Add(response);

            var parameters = new DialogParameters { 
                ["CatchResult"] = response, 
                ["IsNight"] = isNightMode 
            };

            var options = new DialogOptions { 
                BackdropClick = false, 
                CloseOnEscapeKey = true, 
                MaxWidth = MaxWidth.ExtraSmall, 
                FullWidth = true,
                NoHeader = false
            };
            
            await DialogService.ShowAsync<CatchDialog>("Улов", parameters, options);
        }
    }
    catch (Exception ex) 
    { 
        Console.WriteLine($"Ошибка API: {ex.Message}");
    }

    _animationState = FishingAnimationState.None;
    StateHasChanged();
}
    private void StopTimer()
    {
        isRunning = false;
        cts.Cancel();
        timer?.Dispose();
        _animationState = FishingAnimationState.None;
        StateHasChanged();
    }

private async Task ToggleRain(bool value)
    {
        isRainEnabled = value;
        
        if (isRainEnabled)
        {
            await JS.InvokeVoidAsync("audioInterop.play", "rain-audio");
            await JS.InvokeVoidAsync("audioInterop.setVolume", "rain-audio", rainVolume);
        }
        else
        {
            await JS.InvokeVoidAsync("audioInterop.pause", "rain-audio");
        }
        
        StateHasChanged();
    }

    private async Task UpdateRainVolume(int value)
    {
        rainVolume = value;
        await JS.InvokeVoidAsync("audioInterop.setVolume", "rain-audio", rainVolume);
        StateHasChanged();
    }

    private async Task HandleLakeClick(MouseEventArgs e)
    {
        await JS.InvokeVoidAsync("visualEffects.createRipple", "#lake-container", e.OffsetX, e.OffsetY);
    }

    private async Task TriggerSplash()
    {
        showSplash = true;
        StateHasChanged();
        await Task.Delay(600);
        showSplash = false;
        StateHasChanged();
    }

    private string GetFishingAnimationClass() => _animationState switch
    {
        FishingAnimationState.InitialDrop => "initial-drop",
        FishingAnimationState.PassiveFishing => "passive-fishing",
        FishingAnimationState.ActiveBite => "active-bite",
        FishingAnimationState.FinalRaise => "final-raise",
        _ => ""
    };

    public void Dispose()
    {
        cts.Cancel();
        timer?.Dispose();
    }
}