@page "/"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using FishFocus.Shared.Models
@using System.Threading
@using MudBlazor
@using FishFocus.Client.Dialogs
@implements IDisposable
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService
@using FishFocus.Shared.DTOs.Profile
@using System.Net.Http.Json
@using System.Net.Http.Headers

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<PageTitle>Рыбалка</PageTitle>

<div class="main-container @(isNightMode ? "night-theme" : "day-theme")"
    style="opacity: @(_isAppReady ? "1" : "0"); transition: opacity 0.8s ease-in-out;">
    <div class="lake-area" id="lake-container" @onclick="HandleLakeClick">
        
        <div class="clouds-visual-area">
            <div class="cloud cloud-1"></div>
            <div class="cloud cloud-2"></div>
            <div class="cloud cloud-3"></div>
        </div>

        <div class="fog-overlay @(playFog ? "fog-active" : "")"></div>
        <div class="lightning-flash @(isLightningStrike ? "flash-active" : "")"></div>
        
        @if (_isAppReady)
            {
                <div class="birds-visual-area">
                    <div class="bird-container bird-container-one"><div class="bird bird-one"></div></div>
                    <div class="bird-container bird-container-two"><div class="bird bird-two"></div></div>
                    <div class="bird-container bird-container-three"><div class="bird bird-three"></div></div>
                    <div class="bird-container bird-container-four"><div class="bird bird-four"></div></div>
                </div>
            }

        <div class="lightning-container">
            @foreach (var bolt in _activeBolts)
            {
                <svg class="lightning-bolt" 
                     style="left: @(bolt.Left)%; top: @(bolt.Top)%; width: @(bolt.Width)px; height: @(bolt.Height)px;" 
                     viewBox="0 0 20 40" @key="bolt.Id">
                    <path d="M10 0 L2 20 L18 15 L8 40" fill="none" stroke="white" stroke-width="2" />
                </svg>
            }
        </div>

        @if (isRainInDom) 
        {
            <div class="rain-overlay @(isRainAnimationActive ? "rain-active" : "")" @key="@("rain-layer-v4")">
                @foreach (var drop in _rainDrops)
                {
                    <div class="rain-drop" 
                         style="left: @(drop.Left.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%; 
                                animation-delay: @(drop.Delay.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s; 
                                animation-duration: @(drop.Duration.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s;">
                    </div>
                }
            </div>
        }
        <div class="fishing-ui-group">
<div class="progress-container">
            <MudProgressCircular Color="Color.Primary" Value="@_progressValue" Size="Size.Large" Thickness="2" Style="height:300px; width:300px;">
                <ChildContent>
                     @if (isRunning)
                     {
                        <div class="fishing-scene">
                            <div class="water-line"></div>
                            <div class="bobber @GetFishingAnimationClass()">
                                <div class="bobber-top"></div>
                            </div>
                            <div class="ripples"></div>
                            <div class="splash-effect @(showSplash ? "splash-active" : "")"></div>
                        </div>
                     }
                </ChildContent>
            </MudProgressCircular>
        </div>

        <MudText Typo="Typo.h1" Class="timer-text">@timeDisplay</MudText>

        <div class="quote-area">
            <MudText Typo="Typo.body1" Class="italic-quote">"@_currentQuote"</MudText>
        </div>
        
        @if (_isAppReady)
        {
            @if (!isRunning)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="StartTimer" Class="action-button">
                    Забросить удочку
                </MudButton>
            }
            else
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="StopTimer" Class="action-button">
                    Прервать рыбалку
                </MudButton>
            }
        }
    </div></div>
    <div class="settings-panel">
        <div class="d-flex justify-space-between align-center mb-2">
            <MudText Typo="Typo.h6">Настройки</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" OnClick="OpenLoginDialog" />
        </div>

<div class="time-picker-container mb-2">
            <div class="time-box">
                @* Часы: Вверх *@
                <div class="time-zone top" @onmousedown='(e) => HandleZoneClick("hours", 1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
                </div>
                
                @* Часы: Значение и Инпут *@
                <div class="time-zone middle" @onclick='() => EnableInputMode("hours")'>
                    @if (isHoursInputMode)
                    {
                        <input id="h-input-field" type="number" class="time-input-hidden" 
                               value="@displayHours" 
                               @onchange='(e) => ManualUpdate(e, "hours")' 
                               @onblur='() => isHoursInputMode = false'
                               @onkeydown="@(e => { if (e.Key == "Enter") isHoursInputMode = false; })" />
                    }
                    <span class="time-value">@displayHours</span>
                    <span class="time-label">ч</span>
                </div>

                @* Часы: Вниз *@
                <div class="time-zone bottom" @onmousedown='(e) => HandleZoneClick("hours", -1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
                </div>
            </div>

            <div class="time-box">
                @* Минуты: Вверх *@
                <div class="time-zone top" @onmousedown='(e) => HandleZoneClick("minutes", 1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" />
                </div>

                @* Минуты: Значение и Инпут *@
                <div class="time-zone middle" @onclick='() => EnableInputMode("minutes")'>
                    @if (isMinutesInputMode)
                    {
                        <input id="m-input-field" type="number" class="time-input-hidden" 
                               value="@displayMinutes" 
                               @onchange='(e) => ManualUpdate(e, "minutes")' 
                               @onblur='() => isMinutesInputMode = false' />
                    }
                    <span class="time-value">@displayMinutes.ToString("D2")</span>
                    <span class="time-label">мин</span>
                </div>

                @* Минуты: Вниз *@
                <div class="time-zone bottom" @onmousedown='(e) => HandleZoneClick("minutes", -1)' @onmouseup="HandleMouseUp" @onmouseleave="HandleMouseUp">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
                </div>
            </div>
        </div>
<div class="setting-block">
    <MudSwitch Value="isNightMode" T="bool" ValueChanged="ToggleNightMode" 
               Label="Ночной режим" Color="Color.Secondary" Disabled="@(!_isAppReady)" />
</div>    
<div class="setting-block">
        <MudSwitch Value="isRadioEnabled" T="bool" ValueChanged="ToggleRadio" Label="Радио" 
                   Disabled="@(!_isAppReady)" Color="Color.Secondary" />
        <div class="slider-wrapper @(isRadioEnabled ? "is-visible" : "")">
            <MudSlider T="int" Value="radioVolume" ValueChanged="UpdateRadioVolume" 
                       Disabled="@(!_isAppReady)" Min="0" Max="100" />
        </div>
    </div>
    
<div class="setting-block">
        <MudSwitch Value="isRainEnabled" T="bool" ValueChanged="ToggleRain" Label="Дождь" 
                   Disabled="@(!_isAppReady)" Color="Color.Info" />
    </div>

    <div class="setting-block">
        <MudSwitch Value="isThunderEnabled" T="bool" ValueChanged="ToggleThunder" Label="Гром" 
                   Disabled="@(!_isAppReady)" Color="Color.Warning" />
    </div>

    <div class="setting-block">
        <MudSwitch Value="isBirdsEnabled" T="bool" ValueChanged="ToggleBirds" Label="Птицы" 
                   Disabled="@(!_isAppReady)" Color="Color.Success" />
    </div>

    <div class="setting-block">
    <MudSwitch Value="playFog" T="bool" ValueChanged="ToggleFog" 
               Label="Туман" Color="Color.Info" Disabled="@(!_isAppReady)" />
    </div>

    <div class="score-display-panel mb-2">
            <div class="score-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Size="Size.Medium" />
            </div>
            <div class="score-text-box">
                <span class="score-label">Мои очки</span>
                <span class="score-value">@TotalScore</span>
            </div>
        </div>


        @if (showDevTools)
        {
            <div class="mt-auto pt-4 border-t-1" style="border-top: 1px solid rgba(255,255,255,0.1)">
                <TestTools IsRunning="@isRunning" 
                           SelectedMinutes="@selectedMinutes" 
                           OnFastForward="@(() => secondsLeft = 5)" />
            </div>
        }
    </div> 
</div>

<audio id="radio-audio" src="@currentTrackUrl" @onended="PlayNextTrack"></audio>
<audio id="thunder-audio" src="audio/thunder.mp3" loop></audio>
<audio id="birds-audio" src="audio/birds.mp3" loop></audio>
<audio id="rain-audio" src="audio/rain.mp3" loop></audio>
<audio id="fish-sound1" src="audio/fish-sound1.mp3"></audio>
<audio id="fish-sound2" src="audio/fish-sound2.mp3"></audio>
<audio id="fish-warning" src="audio/fish-warning.mp3"></audio>


@code {
    private bool isRadioEnabled = false;
    private int radioVolume = 50;
    private string currentTrackUrl = "";
    private int currentTrackIndex = 1;
    private bool isRadioInitialized = false;
    private bool isRainEnabled = false;
    private int rainVolume = 50;
    private bool playFog = false;
    private bool showDevTools = true;
    private bool showSplash = false;
    private bool isNightMode = false;
    private int selectedMinutes = 30;
    private int secondsLeft = 1800;
    private bool isRunning = false;
    private double _progressValue = 0;
    private string _currentQuote = "Забросьте удочку и начните путь к спокойствию...";
    private bool _halfTimeNagSent = false;
    private PeriodicTimer? timer;
    private CancellationTokenSource cts = new();
    private FishCatchResult? catchResult;
    private int TotalScore = 0;
    private List<FishCatchResult> CatchHistory = new();
    private string timeDisplay => $"{(secondsLeft / 60):D2}:{(secondsLeft % 60):D2}";
    private CancellationTokenSource? _adjustCts;
    private bool _isAdjusting = false;
    private bool isRainInDom = false;
    private bool isRainAnimationActive = false;
    private List<RainDropData> _rainDrops = new();
    private class RainDropData
    {
        public double Left { get; set; }
        public double Delay { get; set; }
        public double Duration { get; set; }
    }


    private bool _warning30Played = false;
    private bool _fourSecondsPlayed = false;

    private DateTime _lastSoundTime = DateTime.MinValue;


    private async Task HandleZoneClick(string type, int step)
    {
        if (isRunning) return;

        _isAdjusting = true;
        _adjustCts = new CancellationTokenSource();

        try
        {
            int currentDelay = 300;

            while (_isAdjusting && !_adjustCts.Token.IsCancellationRequested)
            {
                ChangeValue(type, step);

                var now = DateTime.Now;
                if ((now - _lastSoundTime).TotalMilliseconds > 80)
                {
                    _lastSoundTime = now;

                    _ = JS.InvokeVoidAsync("playTickSound");
                }

                StateHasChanged();

                await Task.Delay(currentDelay, _adjustCts.Token);

                if (currentDelay > 50)
                    currentDelay -= 40;
            }
        }
        catch (TaskCanceledException) { }
    }




private async Task ToggleNightMode(bool value)
{
    isNightMode = value;
    await SaveUserSettings();
}

private async Task ToggleFog(bool value)
{
    playFog = value;
    await SaveUserSettings();
}



    private async Task ToggleRadio(bool value)
    {
        isRadioEnabled = value;

        if (isRadioEnabled)
        {
            try 
            {
                if (!isRadioInitialized)
                {
                    currentTrackIndex = Random.Shared.Next(1, 11);
                    currentTrackUrl = $"audio/radio/track{currentTrackIndex}.mp3";
                    isRadioInitialized = true;
                    StateHasChanged();
                    await Task.Delay(300);
                    await JS.InvokeVoidAsync("audioInterop.play", "radio-audio");
                    double randomStartTime = Random.Shared.Next(10, 60); 
                    await JS.InvokeVoidAsync("audioInterop.setCurrentTime", "radio-audio", randomStartTime);
                }
                await UpdateRadioVolume(radioVolume);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка радио: {ex.Message}");

            }
        }
        else
        {
            await JS.InvokeVoidAsync("audioInterop.setVolume", "radio-audio", 0);
        }
        await SaveUserSettings();
    }

    private bool isThunderEnabled = false;
    private int thunderVolume = 50;
    private bool isLightningStrike = false;
    private List<LightningData> _activeBolts = new();
    private bool isBirdsEnabled = false;
    private int birdsVolume = 50;
    private class LightningData { public Guid Id = Guid.NewGuid(); public int Left, Top, Width, Height; }
    private async Task ToggleThunder(bool value)
    {
        isThunderEnabled = value;
        if (isThunderEnabled) { 
            await JS.InvokeVoidAsync("audioInterop.play", "thunder-audio");
            await UpdateThunderVolume(thunderVolume);
            _ = RunThunderLoop(); 
        }
        else { await JS.InvokeVoidAsync("audioInterop.pause", "thunder-audio"); }
    }
    
    private async Task UpdateThunderVolume(int value)
    {
        thunderVolume = value;
        await JS.InvokeVoidAsync("audioInterop.setVolume", "thunder-audio", value);
    }

    private async Task RunThunderLoop()
    {
        var rnd = new Random();
        while (isThunderEnabled)
        {
            await Task.Delay(rnd.Next(10000, 20000));
            if (!isThunderEnabled) break;
            int count = rnd.Next(1, 4);
            for (int i = 0; i < count; i++) {
                var bolt = new LightningData { Left = rnd.Next(10, 90), Top = rnd.Next(0, 20), Width = rnd.Next(40, 80), Height = rnd.Next(150, 250) };
                _activeBolts.Add(bolt);
                await InvokeAsync(StateHasChanged);
                _ = Task.Delay(400).ContinueWith(async t => { _activeBolts.Remove(bolt); await InvokeAsync(StateHasChanged); });
                await Task.Delay(rnd.Next(200, 500));
            }
        }
    }

    private bool _isAppReady = false; // Наш главный предохранитель
    private bool _isFirstLoad = true; // Дополнительный флаг

    private class BirdData 
{ 
    public Guid Id { get; set; } = Guid.NewGuid(); 
    public string BirdClass { get; set; } // Например, "bird-one"
    public int Top { get; set; } 
    public double Speed { get; set; } 
    public double Delay { get; set; } 
}

private List<BirdData> _activeBirds = new(); // Список летящих птиц

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender)
    {
        // Сначала загружаем настройки пользователя
        await LoadUserSettings();

        // Небольшая задержка для плавного появления (ваша логика)
        await Task.Delay(3000);
        _isAppReady = true;

        // Запускаем цикл птиц
        _ = RunContinuousBirdsLoop();
        
        // Уведомляем систему, что состояние изменилось
        await InvokeAsync(StateHasChanged);
    }
}

private async Task RunContinuousBirdsLoop()
{
    var rnd = new Random();
    string[] birdClasses = { "bird-one", "bird-two", "bird-three", "bird-four" };

    while (true)
    {
        int count = rnd.Next(2, 5);
        int baseTop = rnd.Next(5, 16);

        for (int i = 0; i < count; i++)
        {
            var bird = new BirdData
            {
                BirdClass = birdClasses[rnd.Next(birdClasses.Length)],
                Top = baseTop + rnd.Next(-3, 4),
                Speed = 15.0 + rnd.NextDouble() * 5.0,
                Delay = i * 0.7
            };
            _activeBirds.Add(bird);
            
            _ = Task.Delay((int)((bird.Speed + bird.Delay) * 1000) + 2000).ContinueWith(async t => {
                _activeBirds.Remove(bird);
                await InvokeAsync(StateHasChanged);
            });
        }
        
        await InvokeAsync(StateHasChanged);
        await Task.Delay(rnd.Next(10000, 25000));
    }
}
    private async Task LoadUserSettings()
{
    var token = await JS.InvokeAsync<string?>("localStorage.getItem", "jwt_token");
    if (string.IsNullOrEmpty(token)) return;

    Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

    try
    {
        var profile = await Http.GetFromJsonAsync<UserProfileDto>("api/profile");
        if (profile is null) return;

        isNightMode = profile.IsNightMode;
        playFog = profile.PlayFog;
        isRadioEnabled = profile.IsRadioEnabled;
        radioVolume = profile.RadioVolume;
        isRainEnabled = profile.IsRainEnabled;
        rainVolume = profile.RainVolume;

        StateHasChanged();

        // Применяем загруженные настройки звука к элементам DOM
        if (isRadioEnabled)
        {
            if (!isRadioInitialized)
            {
                currentTrackIndex = Random.Shared.Next(1, 11);
                currentTrackUrl = $"audio/radio/track{currentTrackIndex}.mp3";
                isRadioInitialized = true;
                StateHasChanged();
                await Task.Delay(300);
                await JS.InvokeVoidAsync("audioInterop.play", "radio-audio");
                double randomStartTime = Random.Shared.Next(10, 60);
                await JS.InvokeVoidAsync("audioInterop.setCurrentTime", "radio-audio", randomStartTime);
            }
            await JS.InvokeVoidAsync("audioInterop.setVolume", "radio-audio", radioVolume);
        }

        if (isRainEnabled)
        {
            // Инициализация капель дождя, если он включен
            var rnd = new Random();
            _rainDrops = Enumerable.Range(0, 60).Select(_ => new RainDropData
            {
                Left = rnd.NextDouble() * 100,
                Delay = rnd.NextDouble() * 2,
                Duration = 0.6 + rnd.NextDouble() * 0.4
            }).ToList();
            isRainInDom = true;
            isRainAnimationActive = true;

            await JS.InvokeVoidAsync("audioInterop.play", "rain-audio");
            await JS.InvokeVoidAsync("audioInterop.setVolume", "rain-audio", rainVolume);
        }
    }
    catch { }
}

private async Task SaveUserSettings()
{
    var token = await JS.InvokeAsync<string?>("localStorage.getItem", "jwt_token");
    if (string.IsNullOrEmpty(token)) return;

    Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

    var settings = new UpdateSettingsRequest
    {
        IsNightMode = isNightMode,
        PlayFog = playFog,
        IsRadioEnabled = isRadioEnabled,
        RadioVolume = radioVolume,
        IsRainEnabled = isRainEnabled,
        RainVolume = rainVolume,
    };

    try
    {
        await Http.PutAsJsonAsync("api/profile/settings", settings);
    }
    catch { }
}
    private bool _isBirdsLoopRunning = false;

    private async Task ToggleBirds(bool value)
    {
        isBirdsEnabled = value;

        if (isBirdsEnabled)
        {
            await JS.InvokeVoidAsync("audioInterop.play", "birds-audio");
            await JS.InvokeVoidAsync("audioInterop.setVolume", "birds-audio", birdsVolume);
        }
        else
        {
            _ = FadeOutBirdsAudio();
        }
    }

    private async Task FadeOutBirdsAudio()
    {
        int currentVol = birdsVolume;
        while (currentVol > 0)
        {
            currentVol -= 5;
            if (currentVol < 0) currentVol = 0;
            await JS.InvokeVoidAsync("audioInterop.setVolume", "birds-audio", currentVol);
            await Task.Delay(150);
        }
        await JS.InvokeVoidAsync("audioInterop.pause", "birds-audio");
    }

    private async Task UpdateBirdsVolume(int value)
    {
        birdsVolume = value;
        await JS.InvokeVoidAsync("audioInterop.setVolume", "birds-audio", birdsVolume);
    }
    
    private async Task UpdateRadioVolume(int value)
    {
        radioVolume = value;
        int actualVolume = isRadioEnabled ? radioVolume : 0;
        await JS.InvokeVoidAsync("audioInterop.setVolume", "radio-audio", actualVolume);
        await SaveUserSettings();
    }

    private async Task PlayNextTrack()
    {
        currentTrackIndex = currentTrackIndex >= 10 ? 1 : currentTrackIndex + 1;
        currentTrackUrl = $"audio/radio/track{currentTrackIndex}.mp3";
    
        StateHasChanged();
        await Task.Delay(100);
    
        await JS.InvokeVoidAsync("audioInterop.play", "radio-audio");
        await UpdateRadioVolume(radioVolume);
    }

    private async Task OpenLoginDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LoginDialog>("Личный кабинет", options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadUserSettings();
            Snackbar.Add("Настройки синхронизированы!", Severity.Success);
        }
    }
    private int displayHours = 0;
    private int displayMinutes = 30;
    private bool isHoursInputMode = false;
    private bool isMinutesInputMode = false;
    private bool isMouseDown = false;

    private void SyncSelectedMinutes()
    {
        if (displayHours >= 2) 
        {
            displayHours = 2;
            displayMinutes = 0;
        }
    
        selectedMinutes = (displayHours * 60) + displayMinutes;
        // Убираем: if (selectedMinutes < 1) selectedMinutes = 1;
    
        if (!isRunning) secondsLeft = selectedMinutes * 60;
        StateHasChanged();
    }
    private async Task HandleMouseDown(MouseEventArgs e, string type)
    {
        if (isRunning || isHoursInputMode || isMinutesInputMode) return;

        bool isTopHalf = e.OffsetY < 40;
        int step = isTopHalf ? 1 : -1;

        _isAdjusting = true;
        _adjustCts = new CancellationTokenSource();

        try
        {
            int currentDelay = 300;
            
            while (_isAdjusting)
            {
                ChangeValue(type, step);
                StateHasChanged();

                await Task.Delay(currentDelay, _adjustCts.Token);

                if (currentDelay > 50) currentDelay -= 40; 
            }
        }
        catch (TaskCanceledException) { }
    }

    private void HandleMouseUp()
    {
        _isAdjusting = false;
        _adjustCts?.Cancel();
    }

    private void HandleWheel(WheelEventArgs e, string type)
    {
        if (isRunning || !isMouseDown) return;

        int step = e.DeltaY < 0 ? 1 : -1;
        ChangeValue(type, step);
    }

    private void ChangeValue(string type, int step)
    {
        if (isHoursInputMode || isMinutesInputMode) return;

        if (type == "hours")
        {
            displayHours += step;
            if (displayHours > 2) displayHours = 0;
            if (displayHours < 0) displayHours = 2;
        }
        else
        {
            displayMinutes += step;
            if (displayMinutes > 59) displayMinutes = 0;
            if (displayMinutes < 0) displayMinutes = 59;
        }
        SyncSelectedMinutes();
    }

    private async Task EnableInputMode(string type)
    {
        if (isRunning) return;
        HandleMouseUp();
        if (type == "hours") isHoursInputMode = true;
        else isMinutesInputMode = true;
        StateHasChanged();  
        await Task.Delay(50);
        string elementId = type == "hours" ? "h-input-field" : "m-input-field";
        await JS.InvokeVoidAsync("audioInterop.focusElement", elementId);
    }

    private void ManualUpdate(ChangeEventArgs e, string type)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            if (type == "hours") displayHours = Math.Clamp(val, 0, 2);
            else displayMinutes = Math.Clamp(val, 0, 59);
        }
        isHoursInputMode = false;
        isMinutesInputMode = false;
        SyncSelectedMinutes();
    }

